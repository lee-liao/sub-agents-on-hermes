{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Bash(mkdir *)",
      "Bash(python3 *)",
      "Bash(echo *)",
      "Bash(curl *)",
      "mcp__azure-devops__list_projects",
      "mcp__azure-devops__get_work_item"
    ]
  },
  "enabledMcpjsonServers": [
    "azure-devops"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/confine_writes.py\""
          }
        ]
      }
    ]
  }
}
