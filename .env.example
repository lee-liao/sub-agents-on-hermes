# Anthropic auth template — copy to .env and fill in. NEVER commit .env (gitignored).
#
# Two supported forms — pick ONE and wire the matching vars through docker-compose.yml.

# Form 1 — direct Anthropic API key (default endpoint).
# Uncomment, fill in, and keep ANTHROPIC_API_KEY in docker-compose.yml.
# ANTHROPIC_API_KEY=sk-ant-

# Form 2 — custom endpoint / relay (this deployment's choice).
# Used by the hermes-lee container; keep ANTHROPIC_AUTH_TOKEN, ANTHROPIC_BASE_URL,
# and API_TIMEOUT_MS in docker-compose.yml.
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
API_TIMEOUT_MS=
